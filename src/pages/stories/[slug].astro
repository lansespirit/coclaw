---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { buildWeightedTokens, topRelated } from '../../lib/related';
import {
  IconArrowRight,
  IconArrowTopRightOnSquare,
  IconChevronLeft,
  IconCopy,
  IconQuote,
} from '../../components/icons';

export const getStaticPaths = (async () => {
  const stories = await getCollection('stories', ({ data }) => !data.draft);
  return stories.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();

const {
  title,
  storyType,
  name,
  role,
  company,
  avatar,
  ogImage,
  summary,
  dek,
  quote,
  publishDate,
  updatedDate,
  sources,
  topics,
  seoTitle: customSeoTitle,
  seoDescription,
  canonicalPath,
  robots,
  noindex,
} = entry.data;

const storyTypeLabels = {
  person: 'Person story',
  company: 'Company story',
  project: 'Project case',
  incident: 'Incident report',
  ecosystem: 'Ecosystem story',
} as const;

const og = ogImage || '/images/og/og-main.png';
const sourceList = sources ?? [];
const topicList = topics ?? [];
const keywordsMeta = topicList.join(', ');
const resolvedDescription = seoDescription ?? summary;
const seoTitle = customSeoTitle ?? `${title} | CoClaw Stories`;
const publishedLabel = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const updatedAt = updatedDate ?? publishDate;
const updatedLabel = updatedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const showUpdatedInfo = updatedAt.getTime() !== publishDate.getTime();
const storyTypeLabel = storyTypeLabels[storyType];

const allStories = await getCollection('stories', ({ data }) => !data.draft);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);

const seedTokens = buildWeightedTokens([
  { text: title, weight: 4 },
  { text: name, weight: 3 },
  { text: role, weight: 2 },
  { text: company, weight: 2 },
  { text: dek, weight: 3 },
  { text: summary, weight: 2 },
  { text: topicList, weight: 2 },
]);

const relatedStories = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allStories.map((storyEntry) => ({
    id: storyEntry.slug,
    tokens: buildWeightedTokens([
      { text: storyEntry.data.title, weight: 4 },
      { text: storyEntry.data.name, weight: 3 },
      { text: storyEntry.data.role, weight: 2 },
      { text: storyEntry.data.company, weight: 2 },
      { text: storyEntry.data.dek, weight: 3 },
      { text: storyEntry.data.summary, weight: 2 },
      { text: storyEntry.data.topics, weight: 2 },
    ]),
    item: storyEntry,
  })),
  limit: 3,
  minScore: 0.08,
}).map(({ item }) => ({
  href: `/stories/${item.slug}`,
  title: item.data.title,
  description: item.data.summary,
  badge: storyTypeLabels[item.data.storyType],
}));

const relatedGuides = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allGuides.map((guideEntry) => ({
    id: guideEntry.slug,
    tokens: buildWeightedTokens([
      { text: guideEntry.data.title, weight: 3 },
      { text: guideEntry.data.description, weight: 2 },
      { text: guideEntry.data.keywords ?? [], weight: 2 },
      { text: guideEntry.data.category, weight: 1 },
      { text: guideEntry.data.platforms ?? [], weight: 1 },
    ]),
    item: guideEntry,
  })),
  limit: 2,
}).map(({ item }) => ({
  href: `/guides/${item.slug}`,
  title: item.data.title,
  description: item.data.description,
  badge: 'Guide',
}));

const canonicalURL = new URL(canonicalPath || Astro.url.pathname, Astro.site);
const copyBtnId = `copy-story-link-${entry.slug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
const copyLabelId = `${copyBtnId}-label`;

const aboutEntity =
  storyType === 'person'
    ? {
        '@type': 'Person',
        name,
        jobTitle: role,
        worksFor: { '@type': 'Organization', name: company },
      }
    : storyType === 'company'
      ? {
          '@type': 'Organization',
          name: company,
          description: `${name} — ${role}`,
        }
      : storyType === 'project'
        ? {
            '@type': 'SoftwareApplication',
            name,
            description: summary,
            publisher: { '@type': 'Organization', name: company },
          }
        : {
            '@type': 'Thing',
            name: title,
            description: dek,
          };

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: resolvedDescription,
  image: [new URL(og, Astro.site).toString()],
  datePublished: publishDate.toISOString(),
  dateModified: updatedAt.toISOString(),
  author: { '@type': 'Organization', name: 'CoClaw' },
  publisher: { '@type': 'Organization', name: 'CoClaw', url: 'https://coclaw.com' },
  articleSection: storyTypeLabel,
  keywords: topicList,
  about: aboutEntity,
  mainEntityOfPage: canonicalURL.toString(),
};
---

<BaseLayout
  title={seoTitle}
  description={resolvedDescription}
  keywords={keywordsMeta}
  ogImage={og}
  canonicalPath={canonicalPath}
  robots={robots}
  noindex={noindex}
  type="article"
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600;700&family=Prata&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    <meta property="article:modified_time" content={updatedAt.toISOString()} />
  </Fragment>

  <div class="story-feature relative min-h-screen overflow-x-hidden bg-background text-foreground">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div
        class="absolute inset-x-0 top-0 h-[42rem] bg-gradient-to-b from-secondary/8 via-transparent to-transparent dark:from-secondary/14"
      >
      </div>
      <div
        class="absolute -left-24 top-8 h-80 w-80 rounded-full bg-primary/8 blur-3xl dark:bg-primary/16"
      >
      </div>
      <div
        class="absolute right-0 top-28 h-80 w-80 rounded-full bg-secondary/10 blur-3xl dark:bg-secondary/18"
      >
      </div>
      <div class="story-grid absolute inset-0 opacity-35 dark:opacity-20"></div>
    </div>

    <Section as="header" py="pt-18 pb-6 md:pt-22 md:pb-8" containerClass="relative z-10 max-w-7xl">
      <div
        class="flex flex-wrap items-center justify-between gap-4 border-b border-divider/80 pb-5"
      >
        <a
          href="/stories"
          class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.16em] text-default-600 transition hover:text-foreground dark:text-default-500"
        >
          <IconChevronLeft className="h-4 w-4" aria-hidden="true" />
          Back to archive
        </a>

        <div
          class="story-mono flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.72rem] uppercase tracking-[0.22em] text-default-500"
        >
          <time datetime={publishDate.toISOString()}>{publishedLabel}</time>
          <span class="hidden h-1 w-1 rounded-full bg-default-400 md:block"></span>
          <span>{sourceList.length} public sources</span>
          {
            showUpdatedInfo ? (
              <>
                <span class="hidden h-1 w-1 rounded-full bg-default-400 md:block" />
                <span>Updated {updatedLabel}</span>
              </>
            ) : null
          }
        </div>
      </div>

      <div class="mt-8 max-w-[72rem]">
        <div
          class="story-mono flex flex-wrap items-center gap-x-3 gap-y-2 text-[0.72rem] uppercase tracking-[0.24em] text-default-500"
        >
          <span>{storyTypeLabel}</span>
        </div>

        <h1
          class="story-display mt-5 max-w-5xl text-[clamp(4rem,8vw,5.75rem)] leading-[0.92] tracking-[-0.045em] text-foreground"
        >
          {title}
        </h1>

        <div
          class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-default-600 dark:text-default-500"
        >
          <p class="text-lg font-medium text-secondary md:text-[1.7rem]">{name}</p>
          <span class="hidden h-5 w-px bg-divider md:block"></span>
          <p class="text-base text-default-600 dark:text-default-500">{role}</p>
          <span class="hidden h-5 w-px bg-divider md:block"></span>
          <p class="text-sm uppercase tracking-[0.18em] text-default-500">{company}</p>
        </div>

        <p
          class="mt-7 max-w-3xl text-lg leading-8 text-default-800 dark:text-default-600 md:text-[1.26rem]"
        >
          {dek}
        </p>
      </div>
    </Section>

    {
      quote ? (
        <Section py="pt-0 pb-8 md:pb-10" containerClass="relative z-10 max-w-6xl">
          <div class="story-mono flex items-center gap-3 text-[0.72rem] uppercase tracking-[0.26em] text-default-500">
            <span class="h-px flex-1 bg-divider" />
            <span>Opening quote</span>
            <span class="h-px flex-1 bg-divider" />
          </div>
          <blockquote class="mx-auto mt-8 max-w-4xl text-center text-3xl leading-tight text-foreground md:text-5xl md:leading-tight">
            <span class="inline-flex align-top text-secondary">
              <IconQuote className="mr-3 h-8 w-8" aria-hidden="true" />
            </span>
            {quote}
          </blockquote>
        </Section>
      ) : null
    }

    <Section py="pb-24" containerClass="relative z-10 max-w-7xl">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1fr)_20rem] xl:items-start">
        <div>
          <article class="c-content story-prose prose prose-lg prose-primary max-w-none">
            <Content />
          </article>

          {
            sourceList.length ? (
              <section class="mt-16 border-t border-divider pt-10" id="sources">
                <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
                  <div>
                    <p class="story-mono text-xs uppercase tracking-[0.28em] text-default-500">
                      Sources
                    </p>
                    <h2 class="story-display mt-3 text-4xl leading-tight text-foreground">
                      Sources & public record
                    </h2>
                  </div>
                  <p class="max-w-xl text-sm leading-7 text-default-600 dark:text-default-500">
                    CoClaw keeps story pages grounded in public reporting, primary posts, issue
                    threads, and project materials readers can inspect themselves.
                  </p>
                </div>
                <ol class="mt-7 divide-y divide-divider">
                  {sourceList.map((source, index) => (
                    <li class="py-4 first:pt-0">
                      <a
                        href={source.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex items-start justify-between gap-4"
                      >
                        <div>
                          <p class="story-mono text-[0.72rem] uppercase tracking-[0.22em] text-default-500">
                            Source {String(index + 1).padStart(2, '0')}
                          </p>
                          <p class="mt-2 text-base font-medium leading-7 text-foreground">
                            {source.label}
                          </p>
                        </div>
                        <IconArrowTopRightOnSquare
                          className="mt-1 h-5 w-5 shrink-0 text-default-500 transition group-hover:text-primary"
                          aria-hidden="true"
                        />
                      </a>
                    </li>
                  ))}
                </ol>
              </section>
            ) : null
          }
        </div>

        <aside class="xl:sticky xl:top-28 space-y-6">
          <div
            class="rounded-[1.8rem] border border-divider bg-content1/80 p-6 backdrop-blur-xl dark:bg-content1/60"
          >
            <p class="story-mono text-xs uppercase tracking-[0.28em] text-default-500">
              Story dossier
            </p>
            <div class="mt-5 flex items-center gap-4 border-b border-divider pb-5">
              <span
                class="flex h-16 w-16 items-center justify-center overflow-hidden rounded-full border border-divider bg-content2 dark:bg-content2/40"
              >
                <img
                  src={avatar}
                  alt={`${name} avatar`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </span>
              <div>
                <div class="font-semibold text-foreground">{name}</div>
                <div class="text-sm text-default-600 dark:text-default-500">{role}</div>
              </div>
            </div>

            <dl class="mt-5 space-y-4 text-sm">
              <div class="grid grid-cols-[6rem_1fr] gap-3">
                <dt class="text-default-500">Company</dt>
                <dd class="text-foreground">{company}</dd>
              </div>
              <div class="grid grid-cols-[6rem_1fr] gap-3">
                <dt class="text-default-500">Published</dt>
                <dd class="text-foreground">{publishedLabel}</dd>
              </div>
              {
                showUpdatedInfo ? (
                  <div class="grid grid-cols-[6rem_1fr] gap-3">
                    <dt class="text-default-500">Updated</dt>
                    <dd class="text-foreground">{updatedLabel}</dd>
                  </div>
                ) : null
              }
              <div class="grid grid-cols-[6rem_1fr] gap-3">
                <dt class="text-default-500">Type</dt>
                <dd class="text-foreground">{storyTypeLabel}</dd>
              </div>
              <div class="grid grid-cols-[6rem_1fr] gap-3">
                <dt class="text-default-500">Sources</dt>
                <dd class="text-foreground">{sourceList.length} public references</dd>
              </div>
            </dl>

            {
              topicList.length ? (
                <div class="mt-6 border-t border-divider pt-5">
                  <p class="story-mono text-[0.72rem] uppercase tracking-[0.22em] text-default-500">
                    Signals
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {topicList.map((topic) => (
                      <span class="rounded-full border border-divider bg-content2/60 px-3 py-1 text-[0.72rem] uppercase tracking-[0.16em] text-default-600 dark:bg-content2/35 dark:text-default-500">
                        {topic}
                      </span>
                    ))}
                  </div>
                </div>
              ) : null
            }
          </div>

          <div
            class="rounded-[1.8rem] border border-divider bg-content1/80 p-6 backdrop-blur-xl dark:bg-content1/60"
          >
            <p class="story-mono text-xs uppercase tracking-[0.28em] text-default-500">Share</p>
            <p class="mt-3 text-sm leading-7 text-default-600 dark:text-default-500">
              If this story helped your team, send the source-backed page instead of a screenshot.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a
                class="inline-flex items-center justify-center h-10 px-4 rounded-full bg-primary text-primary-foreground font-semibold text-sm hover:opacity-90 transition-opacity"
                href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalURL.toString())}&text=${encodeURIComponent(`${title} — CoClaw Story`)}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                Share on X
              </a>
              <a
                class="inline-flex items-center justify-center h-10 px-4 rounded-full border border-divider bg-content2/60 font-semibold text-sm hover:bg-content2 transition-colors dark:bg-content2/35"
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL.toString())}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                LinkedIn
              </a>
              <button
                id={copyBtnId}
                type="button"
                class="inline-flex items-center justify-center gap-2 h-10 px-4 rounded-full border border-divider bg-content2/60 font-semibold text-sm hover:bg-content2 transition-colors dark:bg-content2/35"
              >
                <IconCopy className="h-4 w-4" aria-hidden="true" />
                <span id={copyLabelId}>Copy link</span>
              </button>
            </div>
          </div>

          <div
            class="rounded-[1.8rem] border border-divider bg-content1/80 p-6 backdrop-blur-xl dark:bg-content1/60"
          >
            <p class="story-mono text-xs uppercase tracking-[0.28em] text-default-500">Next step</p>
            <p class="mt-3 text-sm leading-7 text-default-600 dark:text-default-500">
              New to OpenClaw? Start with a safer, repeatable setup before you try to reproduce what
              this story describes.
            </p>
            <a
              href="/getting-started"
              class="mt-5 inline-flex w-full items-center justify-center rounded-full border border-secondary/25 bg-secondary/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-secondary transition duration-300 hover:-translate-y-0.5 hover:bg-secondary/15"
            >
              Get started with OpenClaw
              <IconArrowRight className="ml-2 h-4 w-4" aria-hidden="true" />
            </a>
          </div>
        </aside>
      </div>

      <RelatedLinks title="Related Stories" items={relatedStories} />
      <RelatedLinks title="Related Guides" items={relatedGuides} />
    </Section>
  </div>
</BaseLayout>

<style>
  .story-feature {
    --story-display: 'Prata', 'Times New Roman', serif;
    --story-sans: 'Instrument Sans', 'Helvetica Neue', sans-serif;
    --story-mono: 'IBM Plex Mono', 'SF Mono', monospace;
    font-family: var(--story-sans);
  }

  .story-display {
    font-family: var(--story-display);
  }

  .story-mono,
  .story-kicker {
    font-family: var(--story-mono);
  }

  .story-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    backdrop-filter: blur(18px);
  }

  .story-kicker::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 20px color-mix(in srgb, currentColor 35%, transparent);
  }

  .story-grid {
    background-image:
      linear-gradient(to right, rgb(0 0 0 / 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(0 0 0 / 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.26), transparent 82%);
  }

  :global(html.dark) .story-grid {
    background-image:
      linear-gradient(to right, rgb(255 255 255 / 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(255 255 255 / 0.05) 1px, transparent 1px);
  }

  .story-prose :global(h2),
  .story-prose :global(h3) {
    font-family: var(--story-display);
    letter-spacing: -0.03em;
    color: inherit;
  }

  .story-prose :global(p:first-of-type) {
    font-size: 1.18em;
    line-height: 1.9;
    color: rgb(0 0 0 / 0.78);
  }

  :global(html.dark) .story-prose :global(p:first-of-type) {
    color: rgb(255 255 255 / 0.72);
  }

  .story-prose :global(blockquote) {
    border-left-width: 1px;
    border-left-color: rgb(120 40 200 / 0.28);
    font-style: normal;
    color: inherit;
  }
</style>

<script
  is:inline
  define:vars={{
    copyBtnId,
    copyLabelId,
    storyUrl: canonicalURL.toString(),
  }}
>
  (() => {
    const btn = document.getElementById(copyBtnId);
    const label = document.getElementById(copyLabelId);
    if (!btn || !label) return;
    const original = label.textContent || 'Copy link';

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(storyUrl);
        label.textContent = 'Copied';
      } catch {
        const input = document.createElement('input');
        input.value = storyUrl;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        label.textContent = 'Copied';
      }
      setTimeout(() => {
        label.textContent = original;
      }, 1500);
    });
  })();
</script>
