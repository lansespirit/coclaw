<style>
  .stories-editorial {
    --stories-display: 'Prata', 'Times New Roman', serif;
    --stories-sans: 'Instrument Sans', 'Helvetica Neue', sans-serif;
    --stories-mono: 'IBM Plex Mono', 'SF Mono', monospace;
    font-family: var(--stories-sans);
  }

  .stories-display {
    font-family: var(--stories-display);
  }

  .stories-mono,
  .stories-kicker {
    font-family: var(--stories-mono);
  }

  .stories-panel {
    border: 1px solid color-mix(in srgb, currentColor 6%, transparent);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.72), rgb(255 255 255 / 0.56)),
      linear-gradient(135deg, rgb(255 255 255 / 0.12), transparent 45%);
    box-shadow: 0 28px 90px -46px rgb(0 0 0 / 0.32);
    backdrop-filter: blur(26px);
  }

  :global(html.dark) .stories-panel {
    background:
      linear-gradient(180deg, rgb(18 18 22 / 0.78), rgb(18 18 22 / 0.62)),
      linear-gradient(135deg, rgb(255 255 255 / 0.05), transparent 45%);
    box-shadow: 0 30px 110px -50px rgb(0 0 0 / 0.78);
  }

  .stories-watchlist {
    background:
      radial-gradient(circle at top left, rgb(245 158 11 / 0.12), transparent 32%),
      linear-gradient(180deg, rgb(255 255 255 / 0.68), rgb(255 255 255 / 0.54));
  }

  :global(html.dark) .stories-watchlist {
    background:
      radial-gradient(circle at top left, rgb(245 158 11 / 0.14), transparent 32%),
      linear-gradient(180deg, rgb(20 20 24 / 0.8), rgb(20 20 24 / 0.64));
  }

  .stories-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    backdrop-filter: blur(18px);
  }

  .stories-kicker::before {
    content: '';
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 20px color-mix(in srgb, currentColor 35%, transparent);
  }

  .stories-title-link {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition:
      color 220ms ease,
      background-size 220ms ease,
      text-shadow 220ms ease;
  }

  .stories-title-link:hover,
  .stories-title-link:focus-visible {
    background-size: 100% 1px;
    outline: none;
  }

  .stories-title-link--primary:hover,
  .stories-title-link--primary:focus-visible {
    color: var(--heroui-primary, currentColor);
    text-shadow: 0 0 18px color-mix(in srgb, var(--heroui-primary, currentColor) 14%, transparent);
  }

  .stories-title-link--secondary:hover,
  .stories-title-link--secondary:focus-visible {
    color: var(--heroui-secondary, currentColor);
    text-shadow: 0 0 18px color-mix(in srgb, var(--heroui-secondary, currentColor) 14%, transparent);
  }

  .stories-filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.78rem 1rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 8%, transparent);
    background: color-mix(in srgb, var(--heroui-content1, white) 76%, transparent);
    color: inherit;
    text-decoration: none;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background-color 220ms ease,
      color 220ms ease;
    backdrop-filter: blur(18px);
  }

  .stories-filter-chip:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--heroui-primary, currentColor) 22%, transparent);
    color: var(--heroui-primary, currentColor);
  }

  .stories-filter-chip__detail {
    color: color-mix(in srgb, currentColor 62%, transparent);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .stories-filter-chip--static {
    padding: 0.5rem 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stories-grid {
    background-image:
      linear-gradient(to right, rgb(0 0 0 / 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(0 0 0 / 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.28), transparent 82%);
  }

  .stories-noise {
    background-image:
      radial-gradient(circle at 20% 20%, rgb(0 0 0 / 0.15) 0.4px, transparent 0.7px),
      radial-gradient(circle at 80% 40%, rgb(0 0 0 / 0.14) 0.4px, transparent 0.7px),
      radial-gradient(circle at 30% 80%, rgb(0 0 0 / 0.12) 0.4px, transparent 0.7px);
    background-size:
      16px 16px,
      22px 22px,
      18px 18px;
    mix-blend-mode: multiply;
  }

  :global(html.dark) .stories-grid {
    background-image:
      linear-gradient(to right, rgb(255 255 255 / 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(255 255 255 / 0.05) 1px, transparent 1px);
  }

  :global(html.dark) .stories-noise {
    background-image:
      radial-gradient(circle at 20% 20%, rgb(255 255 255 / 0.14) 0.4px, transparent 0.7px),
      radial-gradient(circle at 80% 40%, rgb(255 255 255 / 0.12) 0.4px, transparent 0.7px),
      radial-gradient(circle at 30% 80%, rgb(255 255 255 / 0.1) 0.4px, transparent 0.7px);
    mix-blend-mode: screen;
  }

  .animate-rise,
  .animate-rise-delay,
  [style*='animation-delay'] {
    animation: stories-rise 900ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .animate-rise-delay {
    animation-delay: 140ms;
  }

  @keyframes stories-rise {
