---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import {
  IconArrowRight,
  IconCollection,
  IconDocumentText,
  IconQuote,
  IconShieldCheckSolid,
} from '../../components/icons';

const storyEntries = await getCollection('stories', ({ data }) => !data.draft);
const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function formatCountLabel(count: number, singular: string, plural = `${singular}s`) {
  return `${count} ${count === 1 ? singular : plural}`;
}

const storyTypeLabels = {
  person: 'Person story',
  company: 'Company story',
  project: 'Project case',
  incident: 'Incident report',
  ecosystem: 'Ecosystem story',
} as const;

const storyTypeShortLabels = {
  person: 'People',
  company: 'Companies',
  project: 'Projects',
  incident: 'Incidents',
  ecosystem: 'Ecosystem',
} as const;

const storyCtaLabels = {
  person: 'Read story',
  company: 'Read company case',
  project: 'Read project case',
  incident: 'Read incident file',
  ecosystem: 'Read ecosystem story',
} as const;

const stories = storyEntries
  .sort((leftEntry, rightEntry) => {
    if (leftEntry.data.featured !== rightEntry.data.featured) {
      return leftEntry.data.featured ? -1 : 1;
    }

    return rightEntry.data.publishDate.getTime() - leftEntry.data.publishDate.getTime();
  })
  .map((entry) => {
    const updatedDate = entry.data.updatedDate ?? entry.data.publishDate;

    return {
      title: entry.data.title,
      storyType: entry.data.storyType,
      name: entry.data.name,
      role: entry.data.role,
      company: entry.data.company,
      quote: entry.data.quote,
      summary: entry.data.summary,
      dek: entry.data.dek,
      slug: entry.slug,
      href: `/stories/${entry.slug}`,
      featured: entry.data.featured,
      avatar: entry.data.avatar,
      coverImage: entry.data.coverImage,
      publishDate: entry.data.publishDate,
      publishLabel: dateFormatter.format(entry.data.publishDate),
      updatedDate,
      updatedLabel: dateFormatter.format(updatedDate),
      sourceCount: entry.data.sources?.length ?? 0,
      topics: entry.data.topics,
    };
  });

const spotlightPriority = [
  'openclaw-business-owner-cluster',
  'openclaw-use-case-census',
  'openclaw-production-workflow-threshold',
  'openclaw-night-shift-github-issues',
  'openclaw-family-ai-gateway',
  'openclaw-hype-reality-gap',
];

const spotlightStory =
  stories.find((story) => story.featured) ??
  spotlightPriority.map((slug) => stories.find((story) => story.slug === slug)).find(Boolean) ??
  stories[0];
const storiesByNewest = [...stories].sort(
  (leftStory, rightStory) => rightStory.publishDate.getTime() - leftStory.publishDate.getTime()
);
const storiesByUpdated = [...stories].sort(
  (leftStory, rightStory) => rightStory.updatedDate.getTime() - leftStory.updatedDate.getTime()
);
const latestStory = storiesByNewest[0];
const latestUpdatedStory = storiesByUpdated[0];
const totalSources = stories.reduce((count, story) => count + story.sourceCount, 0);

const storyTypeCounts = {
  person: stories.filter((story) => story.storyType === 'person').length,
  company: stories.filter((story) => story.storyType === 'company').length,
  project: stories.filter((story) => story.storyType === 'project').length,
  incident: stories.filter((story) => story.storyType === 'incident').length,
  ecosystem: stories.filter((story) => story.storyType === 'ecosystem').length,
};

const topicCounts = new Map<string, number>();
for (const story of stories) {
  for (const topic of story.topics) {
    topicCounts.set(topic, (topicCounts.get(topic) ?? 0) + 1);
  }
}

const topicFrequency = [...topicCounts.entries()].sort(
  (leftTopic, rightTopic) =>
    rightTopic[1] - leftTopic[1] || leftTopic[0].localeCompare(rightTopic[0])
);
const seoTopics = topicFrequency.map(([topic]) => topic).slice(0, 6);
const primaryTopic = topicFrequency[0]?.[0] ?? 'OpenClaw operations';
const coverageMix = [
  storyTypeCounts.person ? formatCountLabel(storyTypeCounts.person, 'person', 'people') : null,
  storyTypeCounts.project ? formatCountLabel(storyTypeCounts.project, 'project') : null,
  storyTypeCounts.company
    ? formatCountLabel(storyTypeCounts.company, 'company', 'companies')
    : null,
  storyTypeCounts.incident ? formatCountLabel(storyTypeCounts.incident, 'incident') : null,
  storyTypeCounts.ecosystem ? formatCountLabel(storyTypeCounts.ecosystem, 'ecosystem') : null,
]
  .filter(Boolean)
  .slice(0, 3)
  .join(' · ');

const editorialPillars = ['Traced sources', 'Operator stakes', 'Trust in context'];

const collectionKeywords = [
  'OpenClaw stories',
  'OpenClaw case studies',
  'OpenClaw security',
  'OpenClaw incidents',
  'ClawHub',
  'CoClaw',
  ...seoTopics,
].join(', ');

const riskKeywords = [
  'security',
  'trust',
  'moderation',
  'governance',
  'scam',
  'typosquatting',
  'supply chain',
  'distribution',
  'incident',
];

function isRiskStory(story: (typeof stories)[number]) {
  const searchFields = [story.title, story.summary, story.company, ...story.topics]
    .join(' ')
    .toLowerCase();

  return (
    story.storyType === 'incident' || riskKeywords.some((keyword) => searchFields.includes(keyword))
  );
}

const usedStoryHrefs = new Set<string>();
if (spotlightStory) usedStoryHrefs.add(spotlightStory.href);

const latestStories = storiesByNewest
  .filter((story) => !usedStoryHrefs.has(story.href))
  .slice(0, 3);
for (const story of latestStories) usedStoryHrefs.add(story.href);

const watchlistStories = stories
  .filter((story) => !usedStoryHrefs.has(story.href) && isRiskStory(story))
  .slice(0, 3);
for (const story of watchlistStories) usedStoryHrefs.add(story.href);

const operatorPatternPriority = [
  'openclaw-business-owner-cluster',
  'openclaw-use-case-census',
  'openclaw-production-workflow-threshold',
  'openclaw-night-shift-github-issues',
  'openclaw-for-ten-dollars-a-month',
  'openclaw-guardrails-from-your-phone',
];

const lifeSystemPriority = [
  'openclaw-family-ai-gateway',
  'openclaw-changed-my-life',
  'openclaw-plaud-second-brain',
  'openclaw-telegram-mission-control',
];

function takeStoriesByPriority(prioritySlugs: string[], limit: number) {
  const selected = [];
  for (const slug of prioritySlugs) {
    const story = stories.find((candidate) => candidate.slug === slug);
    if (!story || usedStoryHrefs.has(story.href)) continue;
    selected.push(story);
    usedStoryHrefs.add(story.href);
    if (selected.length >= limit) break;
  }
  return selected;
}

const operatorPatternStories = takeStoriesByPriority(operatorPatternPriority, 4);
const lifeSystemStories = takeStoriesByPriority(lifeSystemPriority, 4);
const builderStories = stories.filter((story) => !usedStoryHrefs.has(story.href)).slice(0, 6);

function getStoryCardSubline(story: (typeof stories)[number]) {
  if (story.storyType === 'person') return story.role;
  if (story.storyType === 'incident') return story.company || story.role;
  return story.company || story.role;
}

const storySignals = [
  {
    label: 'Latest published',
    title: latestStory?.title ?? 'Latest story filed',
    detail: latestStory ? latestStory.publishLabel : `${stories.length} stories live`,
  },
  {
    label: 'Recurring thread',
    title: primaryTopic,
    detail: `${topicCounts.get(primaryTopic) ?? 0} stories in this thread`,
  },
  {
    label: 'Coverage mix',
    title: coverageMix || 'People, projects, incidents',
    detail: `${totalSources} public sources across the archive`,
  },
];

const archiveLenses = [
  {
    label: 'Under pressure',
    href: '#watchlist',
    description: 'Security, governance, and scam pressure',
  },
  {
    label: 'Work patterns',
    href: '#operator-patterns',
    description: 'Revenue ops, production thresholds, cost control',
  },
  {
    label: 'Daily systems',
    href: '#life-systems',
    description: 'Family gateways, memory stacks, mobile control',
  },
];

const sectionChips = {
  watchlist: ['Scam pressure', 'Governance drift', 'Distribution risk', 'Trust breaks'],
  operatorPatterns: ['Revenue ops', 'Bounded coding', 'Cost ceilings', 'Mobile oversight'],
  lifeSystems: ['Family gateway', 'Memory layer', 'Chat control', 'Delegated attention'],
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'OpenClaw Stories, Case Studies & Security Lessons',
  description:
    'Source-backed OpenClaw stories, case studies, ClawHub incidents, and security lessons for operators evaluating trust, deployment choices, and ecosystem risk.',
  url: canonicalURL.toString(),
  hasPart: stories.map((story) => ({
    '@type': 'WebPage',
    name: story.title,
    url: new URL(story.href, Astro.site).toString(),
    description: story.summary,
  })),
};
---

<BaseLayout
  title="OpenClaw Stories, Case Studies & Security Lessons | CoClaw"
  description="Source-backed OpenClaw stories, case studies, ClawHub incidents, and security lessons for operators evaluating trust, deployment choices, and ecosystem risk."
  keywords={collectionKeywords}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600;700&family=Prata&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <div
    class="stories-editorial relative min-h-screen overflow-x-hidden bg-background pb-24 text-foreground"
  >
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div
        class="absolute inset-x-0 top-0 h-[44rem] bg-gradient-to-b from-secondary/8 via-transparent to-transparent dark:from-secondary/14"
      >
      </div>
      <div
        class="absolute -left-20 top-12 h-72 w-72 rounded-full bg-primary/10 blur-3xl dark:bg-primary/18"
      >
      </div>
      <div
        class="absolute right-0 top-28 h-72 w-72 rounded-full bg-secondary/10 blur-3xl dark:bg-secondary/18"
      >
      </div>
      <div
        class="absolute left-1/3 top-[28rem] h-60 w-60 rounded-full bg-accent/8 blur-3xl dark:bg-accent/14"
      >
      </div>
      <div class="stories-grid absolute inset-0 opacity-40 dark:opacity-25"></div>
      <div class="stories-noise absolute inset-0 opacity-[0.06] dark:opacity-[0.08]"></div>
    </div>

    <Section py="pt-28 pb-10 md:pt-36 md:pb-12" containerClass="relative z-10">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1.18fr)_22rem] xl:items-start">
        <div class="max-w-[56rem] animate-rise">
          <div
            class="stories-kicker border border-divider bg-content1/70 text-default-700 dark:bg-content1/60 dark:text-default-500"
          >
            CoClaw Stories
          </div>
          <h1
            class="stories-display mt-7 max-w-5xl text-5xl leading-[0.94] tracking-[-0.045em] text-foreground md:text-[5.25rem] xl:text-[6.4rem]"
          >
            OpenClaw stories, case studies,
            <span class="text-secondary"> and security lessons.</span>
          </h1>
          <p
            class="mt-7 max-w-3xl text-lg leading-8 text-default-800 dark:text-default-600 md:text-[1.34rem] md:leading-9"
          >
            For readers trying to understand what actually happened: what shipped, what broke trust,
            what ClawHub amplified, and what operators learned after the first wave of hype.
          </p>
          <div class="mt-8">
            <ul class="flex flex-wrap gap-x-8 gap-y-3">
              {
                editorialPillars.map((pillar) => (
                  <li class="inline-flex items-center gap-2.5 text-sm text-default-700 dark:text-default-500">
                    <IconShieldCheckSolid className="h-4 w-4 text-primary" aria-hidden="true" />
                    <span>{pillar}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-5 text-sm uppercase tracking-[0.18em]">
            <a
              href="#featured-story"
              class="inline-flex items-center gap-2 rounded-full border border-secondary/25 bg-secondary/10 px-5 py-3 font-semibold text-secondary transition duration-300 hover:-translate-y-0.5 hover:bg-secondary/15"
            >
              Read the lead story
              <IconArrowRight className="h-4 w-4" aria-hidden="true" />
            </a>
            <a
              href="#story-archive"
              class="inline-flex items-center gap-2 text-default-600 transition hover:text-foreground dark:text-default-500"
            >
              Browse the sections
            </a>
          </div>
        </div>

        <aside class="animate-rise-delay xl:pt-4">
          <div class="stories-panel rounded-[2rem] p-5 md:p-6">
            <div class="flex items-center justify-between gap-4">
              <p class="stories-mono text-[0.72rem] uppercase tracking-[0.28em] text-default-500">
                How to read this archive
              </p>
              <span
                class="rounded-full border border-divider bg-content2/60 px-3 py-1 text-[0.68rem] uppercase tracking-[0.18em] text-default-600 dark:bg-content2/35 dark:text-default-500"
              >
                Current view
              </span>
            </div>
            <div class="mt-4 grid gap-3">
              {
                storySignals.map((signal) => (
                  <div class="rounded-[1.2rem] border border-divider bg-content2/55 p-3.5 dark:bg-content2/35">
                    <p class="stories-mono text-[0.64rem] uppercase tracking-[0.22em] text-default-500">
                      {signal.label}
                    </p>
                    <p class="mt-2 text-base font-semibold leading-6 text-foreground">
                      {signal.title}
                    </p>
                    <p class="mt-1.5 text-sm leading-6 text-default-700 dark:text-default-500">
                      {signal.detail}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </Section>

    <Section py="pt-0 pb-10 md:pb-12" containerClass="relative z-10">
      <div class="flex flex-wrap items-center gap-3 border-t border-divider/80 pt-6">
        <span class="stories-mono text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
          Recurring themes
        </span>
        {
          seoTopics.map((topic) => (
            <span class="inline-flex items-center rounded-full border border-divider bg-content1/75 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-default-700 dark:bg-content1/60 dark:text-default-500">
              {topic}
            </span>
          ))
        }
      </div>
    </Section>

    {
      spotlightStory && (
        <Section id="featured-story" py="pt-0 pb-14 md:pb-16" containerClass="relative z-10">
          <div class="mb-7 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div class="max-w-3xl">
              <p class="stories-mono text-[0.72rem] uppercase tracking-[0.28em] text-default-500">
                Lead story
              </p>
              <h2 class="stories-display mt-3 text-4xl leading-tight text-foreground md:text-5xl">
                The clearest place to enter the archive right now.
              </h2>
            </div>
            <p class="max-w-xl text-base leading-8 text-default-700 dark:text-default-500">
              One story that captures the current mix of OpenClaw ambition, product behavior, and
              ecosystem risk.
            </p>
          </div>

          <article class="stories-panel overflow-hidden rounded-[2.5rem]">
            <div class="grid gap-0 xl:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)]">
              <div class="p-8 md:p-10 xl:p-12">
                <div class="flex flex-wrap items-center gap-3 text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
                  <span class="inline-flex items-center gap-2 rounded-full border border-divider bg-content2/55 px-4 py-2 dark:bg-content2/35">
                    <IconCollection className="h-4 w-4 text-secondary" aria-hidden="true" />
                    {storyTypeLabels[spotlightStory.storyType]}
                  </span>
                  <span>{spotlightStory.publishLabel}</span>
                  <span class="h-1 w-1 rounded-full bg-default-400" />
                  <span>{spotlightStory.updatedLabel}</span>
                </div>
                <h3 class="stories-display mt-5 max-w-4xl text-4xl leading-[0.98] text-foreground md:text-[3.25rem]">
                  <a
                    href={spotlightStory.href}
                    class="stories-title-link stories-title-link--secondary"
                  >
                    {spotlightStory.title}
                  </a>
                </h3>
                <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-default-600 dark:text-default-500 md:text-base">
                  <span class="font-semibold text-secondary">{spotlightStory.name}</span>
                  <span class="hidden h-1 w-1 rounded-full bg-default-400 md:block" />
                  <span>{spotlightStory.role}</span>
                  <span class="hidden h-1 w-1 rounded-full bg-default-400 md:block" />
                  <span>{spotlightStory.company}</span>
                </div>
                <p class="mt-6 max-w-3xl text-lg leading-8 text-default-800 dark:text-default-600">
                  {spotlightStory.dek}
                </p>
                <blockquote class="mt-7 max-w-3xl border-l border-secondary/30 pl-5 text-2xl leading-relaxed text-foreground md:text-[1.9rem]">
                  <span class="inline-flex align-top text-secondary">
                    <IconQuote className="mr-3 h-7 w-7" aria-hidden="true" />
                  </span>
                  {spotlightStory.quote}
                </blockquote>
                <div class="mt-7 flex flex-wrap gap-2">
                  {spotlightStory.topics.slice(0, 4).map((topic) => (
                    <span class="rounded-full border border-divider bg-content2/60 px-3 py-1 text-[0.72rem] uppercase tracking-[0.16em] text-default-600 dark:bg-content2/35 dark:text-default-500">
                      {topic}
                    </span>
                  ))}
                </div>
              </div>

              <div class="border-t border-divider bg-content2/35 p-5 dark:bg-content2/25 xl:border-t-0 xl:border-l xl:p-6">
                <div class="overflow-hidden rounded-[1.45rem] border border-divider bg-content1/60">
                  {spotlightStory.coverImage ? (
                    <img
                      src={spotlightStory.coverImage}
                      alt={`${spotlightStory.title} cover`}
                      class="aspect-[16/10] w-full object-cover"
                      loading="eager"
                    />
                  ) : (
                    <div class="aspect-[16/10] bg-gradient-to-br from-primary/15 via-content2 to-secondary/10 dark:from-primary/18 dark:via-content2/70 dark:to-secondary/16" />
                  )}
                </div>

                <div class="mt-4 rounded-[1.45rem] border border-divider bg-content1/70 p-4 dark:bg-content1/55">
                  <div class="flex items-center justify-between gap-3">
                    <p class="stories-mono text-[0.66rem] uppercase tracking-[0.24em] text-default-500">
                      Quick read
                    </p>
                    <span class="stories-mono text-[0.62rem] uppercase tracking-[0.18em] text-default-500">
                      {spotlightStory.sourceCount} sources
                    </span>
                  </div>

                  <div class="mt-3 grid gap-3">
                    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                      <div class="rounded-[1rem] border border-divider bg-content2/45 px-3 py-3 dark:bg-content2/30">
                        <p class="stories-mono text-[0.62rem] uppercase tracking-[0.18em] text-default-500">
                          Who
                        </p>
                        <p class="mt-1.5 text-sm font-medium leading-6 text-foreground">
                          {spotlightStory.name}
                        </p>
                      </div>
                      <div class="rounded-[1rem] border border-divider bg-content2/45 px-3 py-3 dark:bg-content2/30">
                        <p class="stories-mono text-[0.62rem] uppercase tracking-[0.18em] text-default-500">
                          Company / project
                        </p>
                        <p class="mt-1.5 text-sm leading-6 text-default-700 dark:text-default-500">
                          {spotlightStory.company}
                        </p>
                      </div>
                    </div>

                    <div class="rounded-[1rem] border border-divider bg-content2/45 px-3 py-3 dark:bg-content2/30">
                      <p class="stories-mono text-[0.62rem] uppercase tracking-[0.18em] text-default-500">
                        What happened
                      </p>
                      <p class="mt-1.5 text-sm leading-6 text-default-700 dark:text-default-500">
                        {spotlightStory.summary}
                      </p>
                    </div>
                  </div>
                </div>

                <a
                  href={spotlightStory.href}
                  class="mt-4 inline-flex w-full items-center justify-between rounded-full border border-secondary/25 bg-secondary/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-secondary transition duration-300 hover:-translate-y-0.5 hover:bg-secondary/15"
                >
                  {storyCtaLabels[spotlightStory.storyType]}
                  <IconArrowRight className="h-4 w-4" aria-hidden="true" />
                </a>
              </div>
            </div>
          </article>
        </Section>
      )
    }

    {
      latestStories.length > 0 && (
        <Section py="py-10 md:py-12" containerClass="relative z-10">
          <div class="mb-7 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div class="max-w-3xl">
              <p class="stories-mono text-[0.72rem] uppercase tracking-[0.28em] text-default-500">
                Recently added
              </p>
              <h2 class="stories-display mt-3 text-4xl leading-tight text-foreground md:text-5xl">
                New stories worth opening first.
              </h2>
            </div>
            <p class="max-w-xl text-base leading-8 text-default-700 dark:text-default-500">
              New stories usually show where OpenClaw is settling: operator playbooks, everyday
              delegation, memory systems, and the routines that survive after the buzz wears off.
            </p>
          </div>

          <div class="grid gap-5 lg:grid-cols-3">
            {latestStories.map((story, storyIndex) => (
              <article
                class="stories-panel animate-rise rounded-[2rem] p-6"
                style={`animation-delay:${storyIndex * 90}ms`}
              >
                <div class="flex flex-wrap items-center gap-3 text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
                  <span>{story.publishLabel}</span>
                  <span class="h-1 w-1 rounded-full bg-default-400" />
                  <span>{storyTypeLabels[story.storyType]}</span>
                </div>
                <h3 class="mt-4 text-2xl font-semibold leading-tight text-foreground">
                  <a href={story.href} class="stories-title-link stories-title-link--primary">
                    {story.title}
                  </a>
                </h3>
                <div class="mt-4 flex items-center gap-3">
                  {story.avatar ? (
                    <img
                      src={story.avatar}
                      alt={`${story.name} avatar`}
                      class="h-11 w-11 rounded-full border border-divider object-cover bg-content2"
                      loading="lazy"
                    />
                  ) : (
                    <div class="h-11 w-11 rounded-full border border-divider bg-content2" />
                  )}
                  <div>
                    <p class="text-sm font-semibold text-secondary">{story.name}</p>
                    <p class="text-sm text-default-600 dark:text-default-500">{story.company}</p>
                  </div>
                </div>
                <p class="mt-5 text-sm leading-7 text-default-700 dark:text-default-500">
                  {story.summary}
                </p>
                <div class="mt-6 flex items-center justify-between gap-4 border-t border-divider pt-5">
                  <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-default-500">
                    <IconDocumentText className="h-4 w-4 text-primary" aria-hidden="true" />
                    {story.sourceCount} sources
                  </span>
                  <a
                    href={story.href}
                    class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-foreground transition hover:text-primary"
                  >
