---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import {
  IconArrowRight,
  IconArrowTopRightOnSquare,
  IconBolt,
  IconChat,
  IconCheck,
  IconDiscord,
  IconLockClosed,
  IconShieldCheckSolid,
  IconSlack,
  IconTelegram,
  IconWhatsApp,
} from '../../components/icons';
import {
  channelBlueprints,
  normalizeKeywords,
  resolveChannelBlueprint,
  sortChannelEntries,
} from '../../lib/channels';
import {
  buildBreadcrumbList,
  buildCollectionPage,
  wrapSchemaGraph,
} from '../../lib/structured-data';

const entries = sortChannelEntries(
  await getCollection('channels', ({ data }) => !data.draft && !data.archived)
);

const knownBlueprintSlugs = new Set(channelBlueprints.map((channel) => channel.slug));
const publishedBySlug = new Map(entries.map((entry) => [entry.slug, entry]));

const blueprintCards = channelBlueprints.map((blueprint) => {
  const entry = publishedBySlug.get(blueprint.slug);

  return {
    ...blueprint,
    title: entry?.data.title ?? blueprint.title,
    description: entry?.data.description ?? blueprint.summary,
    category: entry?.data.category ?? 'Channel Integration',
    estimatedTime: entry?.data.estimatedTime ?? blueprint.complexity,
    keywords: normalizeKeywords(entry?.data.keywords ?? blueprint.focusAreas).slice(0, 4),
    href: entry ? `/channels/${entry.slug}` : undefined,
    statusLabel: entry?.data.subcategory ?? blueprint.kindLabel,
    entry,
  };
});

const extraCards = entries
  .filter((entry) => !knownBlueprintSlugs.has(entry.slug))
  .map((entry) => {
    const blueprint = resolveChannelBlueprint(entry.slug, entry.data.title);

    return {
      ...blueprint,
      title: entry.data.title,
      description: entry.data.description,
      category: entry.data.category,
      estimatedTime: entry.data.estimatedTime ?? blueprint.complexity,
      keywords: normalizeKeywords(entry.data.keywords ?? blueprint.focusAreas).slice(0, 4),
      href: `/channels/${entry.slug}`,
      statusLabel: entry.data.subcategory ?? blueprint.kindLabel,
      entry,
    };
  });

const popularityOrder = [
  'whatsapp',
  'telegram',
  'discord',
  'slack',
  'msteams',
  'signal',
  'line',
  'googlechat',
  'webchat',
  'matrix',
  'twitch',
  'bluebubbles',
  'mattermost',
  'feishu',
  'nextcloud-talk',
  'synology-chat',
  'irc',
  'imessage',
  'zalo',
  'tlon',
  'nostr',
  'zalouser',
] as const;
const popularityIndex = new Map(popularityOrder.map((slug, index) => [slug, index]));
const showcaseChannels = [...blueprintCards, ...extraCards].sort((a, b) => {
  const aRank = popularityIndex.get(a.slug) ?? popularityOrder.length + 50;
  const bRank = popularityIndex.get(b.slug) ?? popularityOrder.length + 50;

  if (aRank !== bRank) return aRank - bRank;
  if (a.href && !b.href) return -1;
  if (!a.href && b.href) return 1;

  return a.title.localeCompare(b.title);
});
const liveCount = entries.length;
const builtInCount = showcaseChannels.filter((channel) =>
  ['core', 'recommended', 'browser', 'legacy'].includes(channel.kind)
).length;
const pluginCount = showcaseChannels.filter((channel) => channel.kind === 'plugin').length;
const topicCloud = [
  'WhatsApp Web',
  'Telegram Bot',
  'Discord Bot',
  'Slack Socket Mode',
  'Microsoft Teams bot',
  'Signal CLI',
  'Google Chat webhook',
  'LINE Messaging API',
  'Matrix rooms',
  'OpenClaw WebChat',
];
const popularHighlights = showcaseChannels.slice(0, 6);

const heroMetrics = [
  {
    value: String(showcaseChannels.length).padStart(2, '0'),
    label: 'documented channels',
    note: 'Guides for WhatsApp, Telegram, Discord, Slack, Signal, Teams, Matrix, LINE, WebChat, and more.',
  },
  {
    value: String(builtInCount).padStart(2, '0'),
    label: 'built-in routes',
    note: 'Core, recommended, browser, and legacy channels that usually make the shortlist first.',
  },
  {
    value: String(pluginCount).padStart(2, '0'),
    label: 'community plugins',
    note: 'Plugin-backed, regional, and self-hosted channels including Feishu, Mattermost, Nextcloud Talk, Twitch, Tlon, and Zalo.',
  },
];

const operatorLanes = [
  {
    title: 'Auth model',
    description:
      'Bot tokens, QR sessions, WebSocket credentials, webhook secrets, or local bridge identities.',
    icon: IconLockClosed,
  },
  {
    title: 'Access control',
    description:
      'Pairing, allowlists, group policy, mention requirements, role checks, and sender boundaries.',
    icon: IconShieldCheckSolid,
  },
  {
    title: 'Verification path',
    description:
      'First DM, group or room test, restart behavior, reconnect health, and known failure drills.',
    icon: IconCheck,
  },
];

const choreography = [
  {
    step: '01',
    title: 'Match the audience',
    description:
      'Decide whether the real target is consumer chat, team workspace chat, self-hosted rooms, or the built-in WebChat console.',
  },
  {
    step: '02',
    title: 'Choose the transport',
    description:
      'Pick the right operational model: QR login, bot token, Socket Mode, HTTP webhook, WebSocket, or local bridge.',
  },
  {
    step: '03',
    title: 'Lock the boundary',
    description:
      'Set pairing, allowlists, requireMention, roles, and group policy before the first broad rollout.',
  },
  {
    step: '04',
    title: 'Prove it under stress',
    description:
      'Validate direct replies, shared spaces, restart behavior, listener state, and one realistic failure before launch.',
  },
];

const iconMap = {
  telegram: IconTelegram,
  whatsapp: IconWhatsApp,
  slack: IconSlack,
  discord: IconDiscord,
  generic: IconChat,
} as const;

const toneStyles = {
  primary: {
    pill: 'border-primary/20 bg-primary/10 text-primary-700 dark:text-primary-300',
    icon: 'text-primary',
    glow: 'bg-primary/14 dark:bg-primary/20',
    line: 'from-primary/35 via-primary/10 to-transparent',
    hover: 'group-hover:text-primary',
    dot: 'bg-primary',
  },
  secondary: {
    pill: 'border-secondary/20 bg-secondary/10 text-secondary-700 dark:text-secondary-300',
    icon: 'text-secondary',
    glow: 'bg-secondary/14 dark:bg-secondary/20',
    line: 'from-secondary/35 via-secondary/10 to-transparent',
    hover: 'group-hover:text-secondary',
    dot: 'bg-secondary',
  },
  accent: {
    pill: 'border-accent/20 bg-accent/10 text-accent-700 dark:text-accent-300',
    icon: 'text-accent',
    glow: 'bg-accent/14 dark:bg-accent/20',
    line: 'from-accent/35 via-accent/10 to-transparent',
    hover: 'group-hover:text-accent',
    dot: 'bg-accent',
  },
  success: {
    pill: 'border-success/20 bg-success/10 text-success-700 dark:text-success-300',
    icon: 'text-success',
    glow: 'bg-success/14 dark:bg-success/20',
    line: 'from-success/35 via-success/10 to-transparent',
    hover: 'group-hover:text-success',
    dot: 'bg-success',
  },
  warning: {
    pill: 'border-warning/20 bg-warning/10 text-warning-700 dark:text-warning-300',
    icon: 'text-warning',
    glow: 'bg-warning/14 dark:bg-warning/20',
    line: 'from-warning/35 via-warning/10 to-transparent',
    hover: 'group-hover:text-warning',
    dot: 'bg-warning',
  },
  danger: {
    pill: 'border-danger/20 bg-danger/10 text-danger-700 dark:text-danger-300',
    icon: 'text-danger',
    glow: 'bg-danger/14 dark:bg-danger/20',
    line: 'from-danger/35 via-danger/10 to-transparent',
    hover: 'group-hover:text-danger',
    dot: 'bg-danger',
  },
} as const;

const pageTitle =
  'OpenClaw Channels Directory | WhatsApp, Telegram, Discord, Slack, Signal, Teams & More';
const pageDescription =
  'OpenClaw channel guides for WhatsApp, Telegram, Discord, Slack, Signal, Microsoft Teams, Google Chat, LINE, Matrix, WebChat, BlueBubbles, and more. Compare setup, pairing, allowlists, webhooks, Socket Mode, QR login, and troubleshooting.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const structuredData = wrapSchemaGraph(
  buildCollectionPage({
    name: 'OpenClaw Channels Directory',
    description: pageDescription,
    url: canonicalURL.toString(),
    items: showcaseChannels
      .filter((channel) => Boolean(channel.href))
      .map((channel) => ({
        name: channel.title,
        url: new URL(channel.href!, Astro.site).toString(),
        description: channel.description,
      })),
  }),
  buildBreadcrumbList([
    { name: 'Home', item: new URL('/', Astro.site).toString() },
    { name: 'Channels', item: canonicalURL.toString() },
  ])
);
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <div class="channels-deck relative min-h-screen overflow-x-hidden bg-background">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div
        class="absolute inset-x-0 top-0 h-[32rem] bg-[radial-gradient(circle_at_top,_hsl(var(--heroui-content1))_0%,_transparent_68%)] opacity-90"
      >
      </div>
      <div
        class="absolute left-[-8rem] top-24 h-72 w-72 rounded-full bg-primary/12 blur-3xl dark:bg-primary/18"
      >
      </div>
      <div
        class="absolute right-[8%] top-48 h-64 w-64 rounded-full bg-secondary/12 blur-3xl dark:bg-secondary/16"
      >
      </div>
      <div
        class="absolute bottom-24 right-[-7rem] h-72 w-72 rounded-full bg-accent/10 blur-3xl dark:bg-accent/14"
      >
      </div>
      <div class="channels-grid absolute inset-0 opacity-55 dark:opacity-35"></div>
      <div class="channels-scanline absolute inset-x-0 top-[18rem] h-px"></div>
    </div>

    <Section as="header" py="pt-28 pb-10 md:pt-36 md:pb-14" containerClass="relative z-10">
      <div class="grid gap-10 xl:grid-cols-[minmax(0,1.35fr)_20rem] xl:items-start">
        <div class="channel-rise max-w-[58rem]">
          <div
            class="channels-kicker border border-divider bg-content1/75 text-default-700 dark:bg-content1/60 dark:text-default-500"
          >
            OpenClaw channels
          </div>

          <div class="mt-8 max-w-5xl">
            <h1
              class="channels-display text-6xl leading-[0.92] tracking-[-0.05em] text-foreground md:text-[5.55rem] xl:text-[7rem]"
            >
              OpenClaw
              <span class="text-secondary"> channels</span>
            </h1>
          </div>

          <p
            class="mt-8 max-w-3xl text-xl leading-9 text-default-700 dark:text-default-500 md:text-[1.38rem]"
          >
            Find the right OpenClaw channel for WhatsApp, Telegram, Discord, Slack, Signal, Teams,
            Google Chat, LINE, Matrix, WebChat, BlueBubbles, and more. Each page covers setup,
            access policy, transport, verification, and troubleshooting.
          </p>

          <div
            class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-default-600 dark:text-default-500"
          >
            <span class="inline-flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-primary"></span>
              Most-used channels first
            </span>
            <span class="inline-flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-secondary"></span>
              Setup, pairing, webhooks
            </span>
            <span class="inline-flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-accent"></span>
              Practical setup notes
            </span>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-5 text-sm uppercase tracking-[0.18em]">
            <a
              href="#channel-lanes"
              class="inline-flex items-center gap-2 font-semibold text-foreground transition hover:text-primary"
            >
              Browse popular channels
              <IconArrowRight className="h-4 w-4" aria-hidden="true" />
            </a>
            <a
              href="/troubleshooting/solutions?component=channel"
              class="inline-flex items-center gap-2 text-default-600 transition hover:text-foreground dark:text-default-500"
            >
              Open channel troubleshooting
              <IconArrowTopRightOnSquare className="h-4 w-4" aria-hidden="true" />
            </a>
          </div>
        </div>

        <aside
          class="channel-rise-delay rounded-[1.8rem] border border-divider bg-content1/75 p-5 shadow-[0_24px_90px_-50px_rgb(0_0_0/0.35)] backdrop-blur-2xl dark:bg-content1/60 dark:shadow-[0_28px_100px_-52px_rgb(0_0_0/0.8)] xl:mt-10"
        >
          <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
            Top OpenClaw Channels
          </p>
          <p class="channels-display mt-4 text-2xl leading-tight text-foreground">
            Top OpenClaw Channels
          </p>
          <p class="mt-3 text-sm leading-6 text-default-700 dark:text-default-500">
            Most-used channels first.
          </p>
          <ul class="mt-5 space-y-2.5 border-t border-divider pt-4">
            {
              popularHighlights.map((channel, index) => (
                <li class="flex items-start justify-between gap-3 py-1 text-sm text-foreground">
                  <div class="flex items-start gap-3 min-w-0">
                    <span class="channels-mono mt-0.5 text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <div class="min-w-0">
                      <p class="font-medium leading-6 text-foreground">{channel.title}</p>
                      <p class="mt-0.5 text-[0.72rem] leading-5 text-default-600 dark:text-default-500">
                        {channel.keywords[0]}
                      </p>
                    </div>
                  </div>
                  <IconBolt className="mt-1 h-4 w-4 shrink-0 text-primary" aria-hidden="true" />
                </li>
              ))
            }
          </ul>
          <p class="mt-4 text-[0.72rem] leading-5 text-default-500">Ordered by current usage.</p>
        </aside>
      </div>
    </Section>

    <Section py="pt-0 pb-8 md:pb-10" containerClass="relative z-10">
      <div class="grid gap-4 md:grid-cols-3">
        {
          heroMetrics.map((metric, index) => (
            <article
              class="channel-rise rounded-[1.6rem] border border-divider bg-content1/72 p-6 shadow-[0_18px_65px_-42px_rgb(0_0_0/0.28)] backdrop-blur-xl dark:bg-content1/60 dark:shadow-[0_22px_82px_-46px_rgb(0_0_0/0.75)]"
              style={`animation-delay: ${index * 110}ms`}
            >
              <p class="channels-mono text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
                {metric.label}
              </p>
              <p class="channels-display mt-3 text-5xl leading-none text-foreground">
                {metric.value}
              </p>
              <p class="mt-4 text-sm leading-7 text-default-700 dark:text-default-500">
                {metric.note}
              </p>
            </article>
          ))
        }
      </div>
    </Section>

    <Section py="pt-0 pb-4 md:pb-6" containerClass="relative z-10">
      <div class="flex flex-wrap items-center gap-3 border-t border-divider/80 pt-6">
        <span class="channels-mono text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
          Common channel searches
        </span>
        {
          topicCloud.map((topic) => (
            <span class="inline-flex items-center rounded-full border border-divider bg-content1/75 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-default-700 dark:bg-content1/60 dark:text-default-500">
              {topic}
            </span>
          ))
        }
      </div>
    </Section>

    <Section id="channel-lanes" py="pt-6 pb-16 md:pb-20" containerClass="relative z-10">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
            OpenClaw channels
          </p>
          <h2 class="channels-display mt-3 text-4xl leading-tight text-foreground md:text-5xl">
            Start with the channels most teams use.
          </h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-default-700 dark:text-default-500">
          The list starts with the most common deployments, then moves into self-hosted, regional,
          and experimental channels.
        </p>
      </div>

      {
        liveCount === 0 && (
          <div class="mt-8 rounded-[1.4rem] border border-divider bg-content1/72 px-5 py-4 text-sm leading-7 text-default-700 shadow-[0_16px_54px_-38px_rgb(0_0_0/0.24)] dark:bg-content1/58 dark:text-default-500 dark:shadow-[0_22px_70px_-42px_rgb(0_0_0/0.75)]">
            No channel guides are published yet. New files in `src/content/channels` will appear
            here automatically.
          </div>
        )
      }

      <div class="mt-8 grid gap-6 xl:grid-cols-2">
        {
          showcaseChannels.map((channel, index) => {
            const CardIcon = iconMap[channel.iconKey] ?? IconChat;
            const tone = toneStyles[channel.tone];
            const cardClass =
              'group relative flex h-full flex-col overflow-hidden rounded-[2rem] border border-divider bg-content1/78 p-6 shadow-[0_22px_78px_-44px_rgb(0_0_0/0.3)] backdrop-blur-2xl transition duration-300 hover:-translate-y-1 hover:bg-content1/85 dark:bg-content1/62 dark:shadow-[0_26px_95px_-48px_rgb(0_0_0/0.82)]';
            const cardBody = (
              <>
                <div class={`absolute inset-x-0 top-0 h-px bg-gradient-to-r ${tone.line}`} />
                <div
                  class={`absolute -right-8 top-6 h-24 w-24 rounded-full blur-3xl ${tone.glow}`}
                />

                <div class="relative flex items-start justify-between gap-4">
                  <div class="flex items-center gap-4">
                    <span
                      class={`inline-flex h-14 w-14 items-center justify-center rounded-[1.15rem] border border-divider bg-content2/70 ${tone.icon}`}
                    >
                      <CardIcon className="h-7 w-7" aria-hidden="true" />
                    </span>
                    <div>
                      <span
                        class={`inline-flex rounded-full border px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.24em] ${tone.pill}`}
                      >
                        {channel.statusLabel}
                      </span>
                      <h3
                        class={`channels-display mt-4 text-3xl leading-tight text-foreground transition ${tone.hover}`}
                      >
                        {channel.title}
                      </h3>
                    </div>
                  </div>

                  {channel.href ? (
                    <span class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-divider bg-content1/70 text-default-500 transition group-hover:text-foreground">
                      <IconArrowRight className="h-5 w-5" aria-hidden="true" />
                    </span>
                  ) : null}
                </div>

                <p class="mt-6 max-w-2xl text-base leading-8 text-default-700 dark:text-default-500">
                  {channel.description}
                </p>

                <div class="mt-6 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-[1.25rem] border border-divider bg-content2/55 p-4 dark:bg-content2/35">
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      Auth model
                    </p>
                    <p class="mt-3 text-sm leading-7 text-foreground">{channel.authModel}</p>
                  </div>
                  <div class="rounded-[1.25rem] border border-divider bg-content2/55 p-4 dark:bg-content2/35">
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      Safety stance
                    </p>
                    <p class="mt-3 text-sm leading-7 text-foreground">{channel.safetyNote}</p>
                  </div>
                </div>

                <div class="mt-5 flex flex-wrap gap-2">
                  {channel.keywords.map((keyword) => (
                    <span class="inline-flex items-center rounded-full border border-divider bg-content2/55 px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-default-600 dark:bg-content2/35 dark:text-default-500">
                      {keyword}
                    </span>
                  ))}
                </div>

                <div class="mt-6 grid gap-4 border-t border-divider/80 pt-5 text-sm text-default-700 dark:text-default-500 sm:grid-cols-[1fr_1fr_auto] sm:items-end">
                  <div>
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      Runtime stance
                    </p>
                    <p class="mt-2 leading-7">{channel.operatingMode}</p>
                  </div>
                  <div>
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      Effort
                    </p>
                    <p class="mt-2 leading-7">{channel.estimatedTime}</p>
                  </div>
                  <div class="justify-self-start sm:justify-self-end">
                    {channel.href ? (
                      <span
                        class={`inline-flex items-center gap-2 font-semibold text-foreground transition ${tone.hover}`}
                      >
                        Open dossier
                        <IconArrowRight className="h-4 w-4" aria-hidden="true" />
                      </span>
                    ) : (
                      <span class="inline-flex items-center gap-2 font-semibold text-default-500">
                        Guide pending
                      </span>
                    )}
                  </div>
                </div>
              </>
            );

            return channel.href ? (
              <a
                href={channel.href}
                class={cardClass}
                style={`animation-delay: ${120 + index * 90}ms`}
              >
                {cardBody}
              </a>
            ) : (
              <article class={cardClass} style={`animation-delay: ${120 + index * 90}ms`}>
                {cardBody}
              </article>
            );
          })
        }
      </div>
    </Section>

    <Section py="pt-0 pb-20 md:pb-24" containerClass="relative z-10">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] xl:items-start">
        <article
          class="overflow-hidden rounded-[2rem] border border-divider bg-content1/78 p-6 shadow-[0_24px_90px_-48px_rgb(0_0_0/0.3)] backdrop-blur-2xl dark:bg-content1/62 dark:shadow-[0_28px_100px_-50px_rgb(0_0_0/0.82)] md:p-8"
        >
          <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
            How to choose
          </p>
          <h2
            class="channels-display mt-3 max-w-3xl text-4xl leading-tight text-foreground md:text-5xl"
          >
            Choose the channel that fits your rollout.
          </h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            {
              choreography.map((item) => (
                <div class="relative rounded-[1.45rem] border border-divider bg-content2/50 p-5 dark:bg-content2/35">
                  <span class="channels-mono text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
                    Step {item.step}
                  </span>
                  <h3 class="mt-3 text-xl font-semibold text-foreground">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-default-700 dark:text-default-500">
                    {item.description}
                  </p>
                </div>
              ))
            }
          </div>
        </article>

        <div class="grid gap-4">
          {
            operatorLanes.map((lane) => {
              const LaneIcon = lane.icon;
              return (
                <article class="rounded-[1.55rem] border border-divider bg-content1/72 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]">
                  <div class="flex items-start gap-4">
                    <span class="inline-flex h-12 w-12 items-center justify-center rounded-[1rem] border border-divider bg-content2/60 text-primary dark:bg-content2/35">
                      <LaneIcon className="h-5 w-5" aria-hidden="true" />
                    </span>
                    <div>
                      <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                        Every page covers
                      </p>
                      <h3 class="mt-2 text-xl font-semibold text-foreground">{lane.title}</h3>
                      <p class="mt-3 text-sm leading-7 text-default-700 dark:text-default-500">
                        {lane.description}
                      </p>
                    </div>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </Section>
  </div>
</BaseLayout>

