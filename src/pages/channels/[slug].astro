---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustSignals from '../../components/content/TrustSignals.astro';
import Section from '../../components/layout/Section.astro';
import {
  IconArrowRight,
  IconArrowTopRightOnSquare,
  IconBolt,
  IconChat,
  IconCheck,
  IconChevronLeft,
  IconDiscord,
  IconLockClosed,
  IconShieldCheckSolid,
  IconSlack,
  IconTelegram,
  IconWhatsApp,
} from '../../components/icons';
import { buildWeightedTokens, topRelated } from '../../lib/related';
import {
  coerceDate,
  normalizeKeywords,
  resolveChannelBlueprint,
  sortChannelEntries,
} from '../../lib/channels';
import { toContributorEntities } from '../../lib/structured-data';
import { deriveChannelSources } from '../../lib/trust-sources';

export const getStaticPaths = (async () => {
  const entries = sortChannelEntries(
    await getCollection('channels', ({ data }) => !data.draft && !data.archived)
  );

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();

const blueprint = resolveChannelBlueprint(entry.slug, entry.data.title);
const title = entry.data.title;
const description = entry.data.description;
const keywords = normalizeKeywords(entry.data.keywords ?? blueprint.focusAreas);
const seoTitle = entry.data.seoTitle ?? `${title} | CoClaw Channels`;
const seoDescription = entry.data.seoDescription ?? description;
const publishDate = coerceDate(entry.data.publishDate);
const lastUpdated = coerceDate(entry.data.lastUpdated);
const hasValidPublishDate = !Number.isNaN(publishDate.getTime());
const hasValidLastUpdated = !Number.isNaN(lastUpdated.getTime());
const publishedLabel = hasValidPublishDate
  ? publishDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : 'Draft in progress';
const updatedLabel = hasValidLastUpdated
  ? lastUpdated.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : undefined;

const allChannels = sortChannelEntries(
  await getCollection('channels', ({ data }) => !data.draft && !data.archived)
);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const allSolutions = await getCollection(
  'troubleshooting',
  ({ data }) => !data.draft && data.kind === 'solution'
);

const seedTokens = buildWeightedTokens([
  { text: title, weight: 3 },
  { text: description, weight: 2 },
  { text: keywords, weight: 2 },
  { text: [entry.data.category, entry.data.subcategory, entry.data.platform], weight: 1 },
]);

const relatedChannels = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allChannels.map((channel) => ({
    id: channel.slug,
    tokens: buildWeightedTokens([
      { text: channel.data.title, weight: 3 },
      { text: channel.data.description, weight: 2 },
      { text: channel.data.keywords ?? [], weight: 2 },
      { text: [channel.data.category, channel.data.subcategory, channel.data.platform], weight: 1 },
    ]),
    item: channel,
  })),
  limit: 2,
  minScore: 0.07,
}).map(({ item }) => ({
  href: `/channels/${item.slug}`,
  title: item.data.title,
  description: item.data.description,
  badge: 'Channel',
}));

const relatedGuides = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allGuides.map((guide) => ({
    id: guide.slug,
    tokens: buildWeightedTokens([
      { text: guide.data.title, weight: 3 },
      { text: guide.data.description, weight: 2 },
      { text: guide.data.keywords ?? [], weight: 2 },
      { text: [guide.data.category, ...(guide.data.platforms ?? [])], weight: 1 },
    ]),
    item: guide,
  })),
  limit: 2,
  minScore: 0.07,
}).map(({ item }) => ({
  href: `/guides/${item.slug}`,
  title: item.data.title,
  description: item.data.description,
  badge: 'Guide',
}));

const relatedSolutions = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allSolutions.map((solution) => ({
    id: solution.slug,
    tokens: buildWeightedTokens([
      { text: solution.data.title, weight: 3 },
      { text: solution.data.description, weight: 2 },
      { text: solution.data.keywords ?? [], weight: 2 },
      { text: solution.data.channel ?? [], weight: 2 },
      { text: [solution.data.component], weight: 1 },
      { text: solution.data.errorSignatures ?? [], weight: 1 },
    ]),
    item: solution,
  })),
  limit: 3,
  minScore: 0.07,
}).map(({ item }) => ({
  href: `/troubleshooting/${item.slug}`,
  title: item.data.title,
  description: item.data.description,
  badge: 'Fix',
}));

const relatedItems = [...relatedChannels, ...relatedGuides, ...relatedSolutions].slice(0, 6);

const signalCards = [
  {
    label: 'Auth model',
    value: blueprint.authModel,
    icon: IconLockClosed,
  },
  {
    label: 'Safety stance',
    value: blueprint.safetyNote,
    icon: IconShieldCheckSolid,
  },
  {
    label: 'Verification ritual',
    value: blueprint.verificationHint,
    icon: IconCheck,
  },
  {
    label: 'Rollout mode',
    value: entry.data.estimatedTime ?? blueprint.complexity,
    icon: IconBolt,
  },
];

const snapshotFacts = [
  { label: 'Category', value: entry.data.category },
  { label: 'Platform', value: entry.data.platform ?? blueprint.title },
  { label: 'Published', value: publishedLabel },
  { label: 'Updated', value: updatedLabel ?? 'Initial release' },
  { label: 'Author', value: entry.data.author || 'CoClaw Team' },
].filter((item) => Boolean(item.value));

if (entry.data.subcategory) {
  snapshotFacts.splice(1, 0, { label: 'Subcategory', value: entry.data.subcategory });
}

const operatorChecklist = blueprint.checklist;
const routeTags = keywords.slice(0, 6);
const keywordsMeta = keywords.length ? keywords.join(', ') : undefined;
const trustSources = deriveChannelSources(entry.slug, entry.body, entry.data.sources);

const fieldNotes = [
  {
    title: 'Primary risk',
    value: blueprint.warning,
  },
  {
    title: 'Best fit',
    value: blueprint.bestUseCase,
  },
  {
    title: 'Operator focus',
    value: blueprint.verificationHint,
  },
];

const iconMap = {
  telegram: IconTelegram,
  whatsapp: IconWhatsApp,
  slack: IconSlack,
  discord: IconDiscord,
  generic: IconChat,
} as const;
const HeroIcon = iconMap[blueprint.iconKey] ?? IconChat;

const toneStyles = {
  primary: {
    pill: 'border-primary/20 bg-primary/10 text-primary-700 dark:text-primary-300',
    icon: 'text-primary',
    glow: 'bg-primary/14 dark:bg-primary/20',
    line: 'from-primary/35 via-primary/10 to-transparent',
    link: 'hover:text-primary',
    dot: 'bg-primary',
  },
  secondary: {
    pill: 'border-secondary/20 bg-secondary/10 text-secondary-700 dark:text-secondary-300',
    icon: 'text-secondary',
    glow: 'bg-secondary/14 dark:bg-secondary/20',
    line: 'from-secondary/35 via-secondary/10 to-transparent',
    link: 'hover:text-secondary',
    dot: 'bg-secondary',
  },
  accent: {
    pill: 'border-accent/20 bg-accent/10 text-accent-700 dark:text-accent-300',
    icon: 'text-accent',
    glow: 'bg-accent/14 dark:bg-accent/20',
    line: 'from-accent/35 via-accent/10 to-transparent',
    link: 'hover:text-accent',
    dot: 'bg-accent',
  },
  success: {
    pill: 'border-success/20 bg-success/10 text-success-700 dark:text-success-300',
    icon: 'text-success',
    glow: 'bg-success/14 dark:bg-success/20',
    line: 'from-success/35 via-success/10 to-transparent',
    link: 'hover:text-success',
    dot: 'bg-success',
  },
  warning: {
    pill: 'border-warning/20 bg-warning/10 text-warning-700 dark:text-warning-300',
    icon: 'text-warning',
    glow: 'bg-warning/14 dark:bg-warning/20',
    line: 'from-warning/35 via-warning/10 to-transparent',
    link: 'hover:text-warning',
    dot: 'bg-warning',
  },
  danger: {
    pill: 'border-danger/20 bg-danger/10 text-danger-700 dark:text-danger-300',
    icon: 'text-danger',
    glow: 'bg-danger/14 dark:bg-danger/20',
    line: 'from-danger/35 via-danger/10 to-transparent',
    link: 'hover:text-danger',
    dot: 'bg-danger',
  },
} as const;

const tone = toneStyles[blueprint.tone];
const canonicalURL = new URL(entry.data.canonicalPath || Astro.url.pathname, Astro.site);
const authorEntity = toContributorEntities([entry.data.author || 'CoClaw Team']);
const reviewedByEntities = toContributorEntities(entry.data.reviewedBy);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: seoDescription,
  datePublished: hasValidPublishDate ? publishDate.toISOString() : undefined,
  dateModified: hasValidLastUpdated
    ? lastUpdated.toISOString()
    : hasValidPublishDate
      ? publishDate.toISOString()
      : undefined,
  author: authorEntity,
  reviewer: reviewedByEntities,
  publisher: { '@type': 'Organization', name: 'CoClaw', url: 'https://coclaw.com' },
  keywords,
  articleSection: entry.data.category,
  citation: trustSources.map((source) => source.url),
  mainEntityOfPage: canonicalURL.toString(),
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={keywordsMeta}
  canonicalPath={entry.data.canonicalPath}
  robots={entry.data.robots}
  noindex={entry.data.noindex}
  author={entry.data.author}
  type="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredData)} />
  {
    hasValidPublishDate && (
      <meta slot="head" property="article:published_time" content={publishDate.toISOString()} />
    )
  }
  {
    hasValidLastUpdated && (
      <meta slot="head" property="article:modified_time" content={lastUpdated.toISOString()} />
    )
  }

  <div class="channel-dossier relative min-h-screen overflow-x-hidden bg-background">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div
        class="absolute inset-x-0 top-0 h-[30rem] bg-[radial-gradient(circle_at_top,_hsl(var(--heroui-content1))_0%,_transparent_70%)] opacity-90"
      >
      </div>
      <div class={`absolute left-[-7rem] top-24 h-72 w-72 rounded-full blur-3xl ${tone.glow}`}>
      </div>
      <div
        class="absolute right-[10%] top-52 h-60 w-60 rounded-full bg-content2/65 blur-3xl dark:bg-content2/30"
      >
      </div>
      <div class="channel-grid absolute inset-0 opacity-55 dark:opacity-35"></div>
    </div>

    <Section as="header" py="pt-28 pb-10 md:pt-34 md:pb-12" containerClass="relative z-10">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <a
          href="/channels"
          class={`inline-flex items-center gap-2 text-sm font-semibold text-default-600 transition ${tone.link} dark:text-default-500`}
        >
          <IconChevronLeft className="h-4 w-4" aria-hidden="true" />
          Back to channels
        </a>
        <a
          href="/troubleshooting/solutions?component=channel"
          class="inline-flex items-center gap-2 text-sm font-semibold text-default-600 transition hover:text-foreground dark:text-default-500"
        >
          Channel troubleshooting
          <IconArrowTopRightOnSquare className="h-4 w-4" aria-hidden="true" />
        </a>
      </div>

      <div class="mt-10">
        <div class="channel-rise max-w-[64rem]">
          <div class="flex flex-wrap items-center gap-4">
            <span
              class={`inline-flex h-16 w-16 items-center justify-center rounded-[1.4rem] border border-divider bg-content1/70 ${tone.icon} shadow-[0_18px_60px_-38px_rgb(0_0_0/0.28)] backdrop-blur-xl dark:bg-content1/55 dark:shadow-[0_20px_72px_-40px_rgb(0_0_0/0.75)]`}
            >
              <HeroIcon className="h-8 w-8" aria-hidden="true" />
            </span>
            <span
              class={`inline-flex rounded-full border px-4 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.24em] ${tone.pill}`}
            >
              OpenClaw Channel
            </span>
          </div>

          <div class="mt-8 max-w-5xl">
            <h1
              class="channels-display text-6xl leading-[0.92] tracking-[-0.05em] text-foreground md:text-[5.4rem] xl:text-[6.5rem]"
            >
              {title}
            </h1>
          </div>

          <p class="mt-4 text-xl text-default-600 dark:text-default-500 md:text-[1.34rem]">
            {blueprint.strapline}
          </p>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-default-700 dark:text-default-500">
            {description}
          </p>

          <div
            class="mt-8 flex flex-wrap items-center gap-3 text-sm text-default-600 dark:text-default-500"
          >
            <span
              class="inline-flex items-center gap-2 rounded-full border border-divider bg-content1/70 px-4 py-2 dark:bg-content1/55"
            >
              <span class={`h-2 w-2 rounded-full ${tone.dot}`}></span>
              {entry.data.platform ?? blueprint.title}
            </span>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-divider bg-content1/70 px-4 py-2 dark:bg-content1/55"
            >
              {entry.data.category}
            </span>
            {
              routeTags[0] ? (
                <span class="inline-flex items-center gap-2 rounded-full border border-divider bg-content1/70 px-4 py-2 dark:bg-content1/55">
                  {routeTags[0]}
                </span>
              ) : null
            }
          </div>
        </div>
      </div>
    </Section>

    <Section py="pt-0 pb-10 md:pb-12" containerClass="relative z-10">
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {
          signalCards.map((card, index) => {
            const CardIcon = card.icon;
            return (
              <article
                class="channel-rise rounded-[1.55rem] border border-divider bg-content1/74 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]"
                style={`animation-delay: ${90 + index * 80}ms`}
              >
                <div class="flex items-center gap-3">
                  <span
                    class={`inline-flex h-11 w-11 items-center justify-center rounded-[1rem] border border-divider bg-content2/60 ${tone.icon} dark:bg-content2/35`}
                  >
                    <CardIcon className="h-5 w-5" aria-hidden="true" />
                  </span>
                  <p class="channels-mono text-[0.7rem] uppercase tracking-[0.24em] text-default-600 dark:text-default-400">
                    {card.label}
                  </p>
                </div>
                <p class="mt-4 text-sm leading-7 text-default-800 dark:text-default-500">
                  {card.value}
                </p>
              </article>
            );
          })
        }
      </div>
    </Section>

    <Section py="pt-0 pb-4 md:pb-6" containerClass="relative z-10">
      <div class="flex flex-wrap items-center gap-3 border-t border-divider/80 pt-6">
        <span class="channels-mono text-[0.72rem] uppercase tracking-[0.24em] text-default-500">
          Route tags
        </span>
        {
          routeTags.map((tag) => (
            <span class="inline-flex items-center rounded-full border border-divider bg-content1/75 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-default-700 dark:bg-content1/60 dark:text-default-500">
              {tag}
            </span>
          ))
        }
      </div>
    </Section>

    <Section py="pt-6 pb-20 md:pb-24" containerClass="relative z-10">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1.12fr)_22rem] xl:items-start">
        <div
          class="overflow-hidden rounded-[2rem] border border-divider bg-content1/80 shadow-[0_24px_95px_-48px_rgb(0_0_0/0.32)] backdrop-blur-2xl dark:bg-content1/62 dark:shadow-[0_30px_110px_-52px_rgb(0_0_0/0.84)]"
        >
          <div class={`h-px bg-gradient-to-r ${tone.line}`}></div>
          <div
            class="grid gap-5 border-b border-divider p-6 md:grid-cols-[minmax(0,1fr)_20rem] md:p-8"
          >
            <div>
              <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
                {blueprint.playbookEyebrow}
              </p>
              <h2 class="channels-display mt-3 text-4xl leading-tight text-foreground md:text-5xl">
                {blueprint.playbookTitle}
              </h2>
              <p class="mt-4 max-w-2xl text-sm leading-7 text-default-700 dark:text-default-500">
                {blueprint.playbookIntro}
              </p>
            </div>
            <div
              class="rounded-[1.35rem] border border-divider bg-content2/55 p-5 dark:bg-content2/35 md:p-6"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p
                    class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500"
                  >
                    {blueprint.watchLabel}
                  </p>
                  <h3 class="mt-3 text-lg font-semibold text-foreground">{blueprint.watchTitle}</h3>
                </div>
                <span class={`mt-1 h-2.5 w-2.5 rounded-full ${tone.dot}`}></span>
              </div>
              <div class="mt-4 border-t border-divider/80 pt-4">
                <p class="text-sm leading-7 text-default-700 dark:text-default-500">
                  {blueprint.warning}
                </p>
              </div>
            </div>
          </div>

          <article
            class="c-content prose prose-lg prose-primary max-w-none px-6 pb-8 pt-8 md:px-8 md:pb-10"
          >
            <Content />
          </article>

          <div class="px-6 pb-8 md:px-8 md:pb-10">
            <TrustSignals
              reviewedBy={entry.data.reviewedBy}
              reviewedAt={entry.data.reviewedAt}
              testedOn={entry.data.testedOn}
              verificationStatus={entry.data.verificationStatus}
              sources={trustSources}
              context="channel"
              class="not-prose mt-10"
            />
          </div>
        </div>

        <div class="space-y-4 xl:sticky xl:top-28">
          <aside
            class="rounded-[1.55rem] border border-divider bg-content1/74 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]"
          >
            <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
              Snapshot
            </p>
            <ul class="mt-4 space-y-4">
              {
                snapshotFacts.map((fact) => (
                  <li class="rounded-[1.1rem] border border-divider bg-content2/50 p-4 dark:bg-content2/35">
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      {fact.label}
                    </p>
                    <p class="mt-2 text-sm leading-7 text-foreground">{fact.value}</p>
                  </li>
                ))
              }
            </ul>
          </aside>

          <aside
            class="rounded-[1.55rem] border border-divider bg-content1/74 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]"
          >
            <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
              Preflight checklist
            </p>
            <ul class="mt-4 space-y-3">
              {
                operatorChecklist.map((item) => (
                  <li class="flex items-start gap-3 text-sm leading-7 text-default-700 dark:text-default-500">
                    <span class={`mt-2 h-2 w-2 rounded-full ${tone.dot}`} />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </aside>

          <aside
            class="rounded-[1.55rem] border border-divider bg-content1/74 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]"
          >
            <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
              Operator notes
            </p>
            <div class="mt-4 space-y-3">
              {
                fieldNotes.map((note) => (
                  <div class="rounded-[1.1rem] border border-divider bg-content2/50 p-4 dark:bg-content2/35">
                    <p class="channels-mono text-[0.68rem] uppercase tracking-[0.24em] text-default-500">
                      {note.title}
                    </p>
                    <p class="mt-2 text-sm leading-7 text-foreground">{note.value}</p>
                  </div>
                ))
              }
            </div>
          </aside>

          {
            relatedItems.length > 0 && (
              <aside class="rounded-[1.55rem] border border-divider bg-content1/74 p-5 shadow-[0_18px_70px_-42px_rgb(0_0_0/0.24)] backdrop-blur-xl dark:bg-content1/58 dark:shadow-[0_24px_88px_-46px_rgb(0_0_0/0.78)]">
                <p class="channels-mono text-xs uppercase tracking-[0.28em] text-default-500">
                  Continue routing
                </p>
                <div class="mt-4 space-y-3">
                  {relatedItems.map((item) => (
                    <a
                      href={item.href}
                      class="group block rounded-[1.1rem] border border-divider bg-content2/50 p-4 transition hover:bg-content2/70 dark:bg-content2/35"
                    >
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <span
                            class={`inline-flex rounded-full border px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.18em] ${tone.pill}`}
                          >
                            {item.badge}
                          </span>
                          <h3
                            class={`mt-3 text-base font-semibold text-foreground transition ${tone.link}`}
                          >
                            {item.title}
                          </h3>
                        </div>
                        <IconArrowRight
                          className="mt-1 h-4 w-4 text-default-500 transition group-hover:text-foreground"
                          aria-hidden="true"
                        />
                      </div>
                      {item.description ? (
                        <p class="mt-3 text-sm leading-7 text-default-700 dark:text-default-500">
                          {item.description}
                        </p>
                      ) : null}
                    </a>
                  ))}
                </div>
              </aside>
            )
          }
        </div>
      </div>
    </Section>
  </div>
</BaseLayout>

<style>
  .channel-dossier {
    --channels-display: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
    --channels-sans: 'Avenir Next', 'Segoe UI', sans-serif;
    --channels-mono: 'IBM Plex Mono', 'SF Mono', monospace;
    font-family: var(--channels-sans);
  }

  .channels-display {
    font-family: var(--channels-display);
  }

  .channels-mono {
    font-family: var(--channels-mono);
  }

  .channel-grid {
    background-image:
      linear-gradient(to right, hsl(var(--heroui-divider) / 0.08) 1px, transparent 1px),
      linear-gradient(to bottom, hsl(var(--heroui-divider) / 0.08) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.56), transparent 86%);
  }

  .channel-rise,
