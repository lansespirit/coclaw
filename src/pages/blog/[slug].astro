---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/layout/Section.astro';
import TrustSignals from '../../components/content/TrustSignals.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { buildWeightedTokens, topRelated } from '../../lib/related';
import { toContributorEntities } from '../../lib/structured-data';
import { deriveArticleSources } from '../../lib/trust-sources';
import { Button, Chip, Avatar } from '@heroui/react';

export const getStaticPaths = (async () => {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();

const {
  title,
  description,
  author,
  publishDate,
  lastUpdated,
  category,
  ogImage,
  keywords,
  seoTitle: customSeoTitle,
  seoDescription,
  canonicalPath,
  robots,
  noindex,
  reviewedBy,
  reviewedAt,
  testedOn,
  verificationStatus,
  contentOwner,
  sources,
} = entry.data;
const fallbackOgImage = '/images/og/og-main.png';
const socialImage = ogImage || fallbackOgImage;
const heroImage = ogImage || undefined;
const seoTitle = customSeoTitle ?? `${title} | CoClaw Blog`;
const resolvedDescription = seoDescription ?? description;
const trustSources = deriveArticleSources(entry.body, sources);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const seedTokens = buildWeightedTokens([
  { text: title, weight: 3 },
  { text: description, weight: 2 },
  { text: keywords ?? [], weight: 2 },
  { text: category, weight: 1 },
]);
const relatedPosts = topRelated({
  seed: { id: entry.slug, tokens: seedTokens },
  candidates: allPosts.map((p) => ({
    id: p.slug,
    tokens: buildWeightedTokens([
      { text: p.data.title, weight: 3 },
      { text: p.data.description, weight: 2 },
      { text: p.data.keywords ?? [], weight: 2 },
      { text: p.data.category, weight: 1 },
    ]),
    item: p,
  })),
  limit: 4,
  minScore: 0.09,
}).map(({ item }) => ({
  href: `/blog/${item.slug}`,
  title: item.data.title,
  description: item.data.description,
  badge: 'Blog',
}));

const canonicalURL = new URL(canonicalPath || Astro.url.pathname, Astro.site);
const publishedLabel = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const authorEntity = toContributorEntities([author]);
const reviewedByEntities = toContributorEntities(reviewedBy);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: resolvedDescription,
  image: [new URL(socialImage, Astro.site).toString()],
  author: authorEntity,
  reviewer: reviewedByEntities,
  publisher: { '@type': 'Organization', name: 'CoClaw', url: 'https://coclaw.com' },
  datePublished: publishDate.toISOString(),
  dateModified: lastUpdated.toISOString(),
  citation: trustSources.map((source) => source.url),
  mainEntityOfPage: canonicalURL.toString(),
};
---

<BaseLayout
  title={seoTitle}
  description={resolvedDescription}
  ogImage={socialImage}
  keywords={keywords?.join(', ')}
  canonicalPath={canonicalPath}
  robots={robots}
  noindex={noindex}
  author={author}
  type="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredData)} />

  <meta slot="head" property="article:published_time" content={publishDate.toISOString()} />
  <meta slot="head" property="article:modified_time" content={lastUpdated.toISOString()} />
  <meta slot="head" property="article:section" content={category} />
  <div class="bg-background min-h-screen relative">
    <!-- Progress Bar (Fixed Top) -->
    <div class="fixed top-0 left-0 w-full h-1 z-50">
      <div id="read-progress" class="h-full bg-primary w-0 transition-all duration-150"></div>
    </div>

    <!-- Hero Header -->
    <header
      class={`relative w-full overflow-hidden ${
        heroImage
          ? 'h-[60vh] min-h-[400px]'
          : 'border-b border-divider/50 bg-gradient-to-b from-primary/[0.08] via-background to-background'
      }`}
    >
      {
        heroImage ? (
          <>
            <img src={heroImage} alt={title} class="absolute inset-0 w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent" />
          </>
        ) : (
          <div aria-hidden="true" class="absolute inset-0 overflow-hidden">
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/40 to-transparent" />
            <div class="absolute -top-24 right-0 h-72 w-72 rounded-full bg-primary/10 blur-3xl" />
            <div class="absolute left-0 top-20 h-64 w-64 rounded-full bg-secondary/10 blur-3xl" />
          </div>
        )
      }

      <div
        class={`w-full ${heroImage ? 'absolute bottom-0 left-0 p-6 md:p-12 lg:p-24' : 'relative px-6 pb-14 pt-24 md:px-12 md:pb-18 md:pt-28 lg:px-24 lg:pb-20 lg:pt-32'}`}
      >
        <div class="max-w-4xl mx-auto overflow-visible">
          <Chip color="primary" variant={heroImage ? 'shadow' : 'flat'} className="mb-6">
            {category}
          </Chip>
          <h1
            class={`font-black tracking-tighter text-foreground mb-8 line-clamp-3 leading-tight ${heroImage ? 'text-4xl md:text-6xl lg:text-7xl' : 'text-4xl md:text-5xl lg:text-6xl text-balance'}`}
          >
            {title}
          </h1>
          {
            !heroImage ? (
              <p class="max-w-3xl text-lg md:text-xl text-default-600 mb-8 leading-relaxed">
                {description}
              </p>
            ) : null
          }
          <div class="flex flex-wrap items-center gap-6">
            <div class="flex items-center gap-3">
              <Avatar name={author} size="sm" isBordered color="primary" />
              <div>
                <p class="text-foreground font-bold leading-none">{author}</p>
                <p class="text-default-500 text-xs mt-1">OpenClaw Team</p>
              </div>
            </div>
            <div class="h-8 w-px bg-divider"></div>
            <p class="text-default-500 font-medium">{publishedLabel} • 8 min read</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Content -->
    <Section py="py-20" containerSize="reading" containerGutter="docs">
      <article class="c-content prose prose-lg prose-primary max-w-none">
        <Content />
      </article>

      <TrustSignals
        reviewedBy={reviewedBy}
        reviewedAt={reviewedAt}
        testedOn={testedOn}
        verificationStatus={verificationStatus}
        sources={trustSources}
        context="blog"
        class="mt-12"
      />

      <RelatedLinks title="Related Posts" items={relatedPosts} />

      <div class="mt-20 pt-12 border-t border-divider">
        <h3 class="text-2xl font-bold mb-8 italic">Shared this insight?</h3>
        <div class="flex gap-4">
          <Button color="primary" radius="full" className="font-bold">Share on X</Button>
          <Button variant="bordered" radius="full" className="font-bold">Copy Link</Button>
        </div>
      </div>
    </Section>
  </div>

  <script is:inline>
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const progress = document.getElementById('read-progress');
      if (progress) progress.style.width = scrolled + '%';
    });
  </script>
</BaseLayout>
